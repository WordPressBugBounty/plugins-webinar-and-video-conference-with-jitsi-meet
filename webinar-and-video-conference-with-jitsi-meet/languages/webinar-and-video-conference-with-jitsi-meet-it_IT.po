#: inc/admin/class-jitsi-jwt-service.php:114
msgid ""
"Could not connect to the token server. Your hosting provider may be "
"blocking outbound connections to port 8090. Please contact your host "
"support."
msgstr ""
"Impossibile connettersi al server dei token. Il tuo provider di hosting "
"potrebbe bloccare le connessioni sulla porta 8090."

#: inc/admin/class-jitsi-jwt-service.php:127
#. translators: 1: HTTP code, 2: API response body
#, php-format
msgid "Token generation failed. The server returned HTTP %1$d: %2$s"
msgstr "Generazione token fallita. Il server ha restituito HTTP %1$d: %2$s"

#: inc/admin/class-jitsi-jwt-service.php:147
msgid "Invalid response from token server."
msgstr "Risposta non valida dal server token."

#: inc/admin/class-jitsi-jwt-service.php:213
#: inc/admin/class-jitsi-jwt-service.php:427
msgid "Please enter a valid URL (include https://)."
msgstr "Inserisci un URL valido (includi https://)."

#: inc/admin/class-jitsi-jwt-service.php:248
msgid "We couldn't reach the verification server. Please try again."
msgstr "Impossibile raggiungere il server di verifica. Riprova."

#: inc/admin/class-jitsi-jwt-service.php:252
msgid ""
"Your hosted server isn't active yet. If you just requested it, wait for our "
"email."
msgstr "Il tuo server non è ancora attivo. Attendi la nostra e-mail."

#: inc/admin/class-jitsi-jwt-service.php:340
msgid ""
"Invalid URL. Please enter a full domain like "
"https://yourbrand.jitsihosted.app"
msgstr ""
"URL non valido. Inserisci un dominio completo (es. "
"https://tuobrand.jitsihosted.app)."

#: inc/admin/class-jitsi-jwt-service.php:358
#. translators: %s = the domain hostname the user typed
#, php-format
msgid ""
"Domain \"%s\" could not be found (DNS lookup failed). Please check the URL "
"and try again."
msgstr "Impossibile trovare il dominio \"%s\"."

#: inc/admin/class-jitsi-jwt-service.php:383
#. translators: %s = the domain hostname
#, php-format
msgid ""
"Domain \"%s\" resolved but the server did not respond. It may be offline or "
"not a Jitsi server."
msgstr "Dominio \"%s\" trovato ma il server non ha risposto."

#: inc/admin/class-jitsi-jwt-service.php:397
#. translators: 1: domain hostname, 2: HTTP status code
#, php-format
msgid ""
"\"%1$s\" is reachable but does not appear to be a Jitsi server (expected "
"HTTP 200 from /config.js, got %2$d). Please double-check the URL."
msgstr "\"%1$s\" è raggiungibile ma non sembra essere un server Jitsi."

#: inc/admin/class-jitsi-jwt-service.php:419
#: inc/admin/class-jitsi-jwt-service.php:514
